{
  "entities": {
    "influencer": {
      "title": "Influencer",
      "description": "Details of an influencer and their private contact info.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string", "description": "Influencer's public name" },
        "profile_image": { "type": "string", "description": "URL to profile image" },
        "banner_image": { "type": "string", "description": "URL to banner image" },
        "private_info": {
          "type": "object",
          "properties": {
            "snapchat": { "type": "string" },
            "whatsapp": { "type": "string" },
            "instagram": { "type": "string" },
            "telegram": { "type": "string" },
            "phoneNumber": { "type": "string" }
          },
          "description": "The private info revealed after subscription"
        },
        "price_id": { "type": "string", "description": "Stripe Price ID for the subscription" },
        "price": { "type": "string", "description": "Display price (e.g., $9.99/mo)" },
        "owner_id": { "type": "string", "format": "uuid", "description": "UID of the user who created this page" },
        "slug": { "type": "string", "description": "Unique URL slug for the landing page" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "owner_id", "slug", "price_id"]
    },
    "subscription": {
      "title": "Subscription",
      "description": "Record of a user's subscription to an influencer.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "user_id": { "type": "string", "format": "uuid", "description": "UID of the subscriber" },
        "influencer_id": { "type": "string", "format": "uuid", "description": "ID of the influencer" },
        "status": { "type": "string", "enum": ["active", "canceled"] },
        "stripe_subscription_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "influencer_id", "status"]
    }
  },
  "tables": {
    "influencers": {
      "schema": "influencer",
      "description": "Table of influencer landing pages"
    },
    "subscriptions": {
      "schema": "subscription",
      "description": "Table of active subscriptions"
    }
  }
}
